# Caddyfile.snippet — вставить ВНУТРЬ блока {$DOMAIN},
# перед финальным "respond 404" (или вместо него — reverse_proxy перехватит всё остальное).
#
# Итоговый блок в /etc/caddy/Caddyfile должен выглядеть так:

{$DOMAIN} {
    tls {$ACME_EMAIL}

    respond /health "ok" 200

    # ── Debug probe: прямой запрос к api.anthropic.com ────────────────────────
    # Проверяет исходящую сеть и TLS к Anthropic без участия gost.
    # curl https://$DOMAIN/probe  → должен вернуть 401 от Anthropic (не ошибку сети)
    handle /probe {
        rewrite * /v1/models
        reverse_proxy https://api.anthropic.com {
            header_up Host api.anthropic.com
        }
    }
    # ──────────────────────────────────────────────────────────────────────────

    # ── Claude HTTP CONNECT proxy (gost на localhost:8443) ────────────────────
    # Кадди принимает TLS, gost обрабатывает HTTP CONNECT и авторизацию.
    reverse_proxy localhost:8443
    # ──────────────────────────────────────────────────────────────────────────
}
