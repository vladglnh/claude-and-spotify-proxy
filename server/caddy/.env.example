# /etc/caddy/.env — loaded by the caddy.service unit (EnvironmentFile)
# Copy to /etc/caddy/.env and fill in real values. Never commit this file.

# Domain that points at this VPS (used in the Caddyfile as {$DOMAIN})
DOMAIN=your.domain.example

# Email for Let's Encrypt registration and expiry notices
ACME_EMAIL=you@example.com
