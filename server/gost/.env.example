# /etc/gost/.env — loaded by the gost-claude.service unit
# Copy to /etc/gost/.env and fill in real values. Never commit this file.

# Credentials for the HTTP CONNECT proxy
GOST_USER=claude-user
GOST_PASS=replace-with-a-strong-password

# TLS certificate files issued by Caddy.
# Replace 'your.domain.example' with your actual domain in both paths.
GOST_CERT=/var/lib/caddy/.local/share/caddy/certificates/acme-v02.api.letsencrypt.org-directory/your.domain.example/your.domain.example.crt
GOST_KEY=/var/lib/caddy/.local/share/caddy/certificates/acme-v02.api.letsencrypt.org-directory/your.domain.example/your.domain.example.key
